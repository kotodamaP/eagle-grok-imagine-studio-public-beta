# Public example only. Do not put real login/session data in this file.
# This plugin does not require XAI_API_KEY or another direct API key.
# Grok integration uses your own logged-in/configured Grok CLI / Grok Build environment.

# Optional: command name or executable path for Grok CLI.
GROK_CLI_COMMAND=grok

# Optional: command names or executable paths for FFmpeg tools.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Optional: Upscayl CLI paths when image upscale is used.
UPSCAYL_BIN=<PATH_TO_UPSCAYL_BIN>
UPSCAYL_MODELS=<PATH_TO_UPSCAYL_MODELS>

# Optional: path to a local Aratako/Irodori-TTS checkout that contains infer.py.
IRODORI_TTS_ROOT=<PATH_TO_IRODORI_TTS>

# Optional: path to a wrapper script compatible with scripts/run_irodori_narration_from_plugin.ps1.
# If set, this takes precedence over IRODORI_TTS_ROOT.
IRODORI_VOICE_READ_RUNNER=<PATH_TO_COMPATIBLE_VOICE_RUNNER>
